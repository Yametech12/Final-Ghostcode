# .env.example - Template for environment variables
# Copy this file to .env and fill in your actual values

# =================================================================
# APP CONFIGURATION
# =================================================================
APP_URL=https://your-app-domain.vercel.app

# =================================================================
# SUPABASE CONFIGURATION
# =================================================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =================================================================
# AI API CONFIGURATION
# =================================================================
# OpenRouter API Key - Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_REFERER=https://your-app-domain.com
OPENROUTER_TITLE=Your App Name

# =================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# =================================================================
# Gmail credentials for verification codes
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# =================================================================
# SERVER CONFIGURATION
# =================================================================
PORT=3000
NODE_ENV=development

# =================================================================
# GOOGLE CLOUD STORAGE (Optional - for file uploads)
# =================================================================
GCP_PROJECT_ID=your_gcp_project_id
GCP_PROJECT_NUMBER=your_gcp_project_number
GCP_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GCP_BUCKET_NAME=your-bucket-name
GCP_WORKLOAD_IDENTITY_POOL_ID=your-workload-identity-pool
GCP_WORKLOAD_IDENTITY_PROVIDER_ID=your-workload-identity-provider

# =================================================================
# SETUP INSTRUCTIONS
# =================================================================
#
# 1. SUPABASE SETUP:
#    - Create project at https://supabase.com
#    - Go to Settings > API to get URL and keys
#    - Generate a new SERVICE_ROLE_KEY (never reuse old ones!)
#
# 2. OPENROUTER SETUP:
#    - Sign up at https://openrouter.ai
#    - Create API key in dashboard
#    - Add credits to your account
#
# 3. GMAIL SETUP:
#    - Enable 2FA on Gmail account
#    - Generate App Password: https://myaccount.google.com/apppasswords
#    - Use App Password (not regular password)
#
# 4. GCP SETUP (Optional):
#    - Create project at https://console.cloud.google.com
#    - Set up Storage bucket
#    - Configure workload identity for Vercel
#
# =================================================================
# SECURITY REMINDERS
# =================================================================
# 🔒 NEVER commit .env files to version control
# 🔒 Use different keys for staging/production environments
# 🔒 Rotate SERVICE_ROLE_KEY every 30-90 days
# 🔒 Monitor API key usage regularly